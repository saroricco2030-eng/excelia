#!/usr/bin/env bash
# ══════════════════════════════════════════════════════════════════════════════
# SECURITY GATE — pre-commit hook
# SECURITY_MASTER v1.0 [금지] 항목 자동 강제 적용
# 설치: bash install_hooks.sh
# 수동 실행: bash .hooks/pre-commit
# ══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

RED='\033[0;31m'
YEL='\033[0;33m'
GRN='\033[0;32m'
CYN='\033[0;36m'
BLD='\033[1m'
NC='\033[0m'

VIOLATIONS=0
WARNINGS=0

# 스테이징된 파일만 검사 (git add된 파일)
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [[ -z "$STAGED" ]]; then
  echo -e "${GRN}✅ 스테이징된 파일 없음 — 검사 생략${NC}"
  exit 0
fi

DART_FILES=$(echo "$STAGED"  | grep '\.dart$'       || true)
JS_FILES=$(echo "$STAGED"    | grep -E '\.(js|ts|mjs|cjs)$' || true)
JSX_FILES=$(echo "$STAGED"   | grep -E '\.(jsx|tsx)$' || true)
RULES_FILES=$(echo "$STAGED" | grep '\.rules$'      || true)
PLIST_FILES=$(echo "$STAGED" | grep '\.plist$'      || true)
XML_FILES=$(echo "$STAGED"   | grep '\.xml$'        || true)
ENV_FILES=$(echo "$STAGED"   | grep -E '^\.env' || true)
ALL_FILES="$STAGED"

echo ""
echo -e "${BLD}${CYN}══════════════════════════════════════════════${NC}"
echo -e "${BLD}${CYN}  SECURITY GATE  │  SECURITY_MASTER v1.0     ${NC}"
echo -e "${BLD}${CYN}══════════════════════════════════════════════${NC}"
echo ""

# ─── 헬퍼 함수 ────────────────────────────────────────────────────────────────

fail() {
  local part="$1" msg="$2" file="$3" line="$4"
  echo -e "  ${RED}[BLOCK]${NC} ${BLD}PART ${part}${NC} — ${msg}"
  echo -e "         파일: ${file}:${line}"
  VIOLATIONS=$((VIOLATIONS + 1))
}

warn() {
  local part="$1" msg="$2" file="$3"
  echo -e "  ${YEL}[WARN] ${NC} PART ${part} — ${msg}"
  [[ -n "$file" ]] && echo -e "         파일: ${file}"
  WARNINGS=$((WARNINGS + 1))
}

# grep_check: 패턴 발견 시 BLOCK
# $1=파일목록 $2=패턴 $3=PART번호 $4=에러메시지 $5=제외패턴(옵션)
grep_check() {
  local files="$1" pattern="$2" part="$3" msg="$4" exclude="${5:-__NO_EXCLUDE__}"
  [[ -z "$files" ]] && return
  while IFS= read -r file; do
    [[ ! -f "$file" ]] && continue
    local content
    content=$(git show ":$file" 2>/dev/null || cat "$file" 2>/dev/null || true)
    while IFS= read -r match; do
      [[ -z "$match" ]] && continue
      if [[ "$exclude" != "__NO_EXCLUDE__" ]] && echo "$match" | grep -qE "$exclude"; then
        continue
      fi
      local linenum
      linenum=$(echo "$content" | grep -n "$pattern" | head -1 | cut -d: -f1)
      fail "$part" "$msg" "$file" "${linenum:-?}"
    done < <(echo "$content" | grep -E "$pattern" || true)
  done < <(echo "$files")
}

# ══════════════════════════════════════════════════════════════════════════════
# PART 3 — 데이터 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 3] 데이터 보안${NC}"

# SharedPreferences에 토큰/시크릿 저장
grep_check "$DART_FILES" "SharedPreferences.*token|prefs\.set.*[Tt]oken|prefs\.set.*[Ss]ecret|prefs\.set.*[Pp]assword" \
  "3" "SharedPreferences에 토큰/시크릿 저장 금지 → flutter_secure_storage 사용"

# 소스코드 API 키 하드코딩
grep_check "$DART_FILES$JS_FILES$JSX_FILES" \
  "(apiKey|api_key|secret|SECRET|PRIVATE_KEY|privateKey)\s*[:=]\s*['\"][A-Za-z0-9/_\-]{20,}['\"]" \
  "3" "API 키/시크릿 하드코딩 금지 → envied(Flutter) 또는 환경변수 사용" \
  "example|test|mock|fake|dummy|placeholder|your_|<|xxx"

# 전역 변수 토큰 저장
grep_check "$DART_FILES" "static\s+(String|var)\s+\w*(token|Token|secret|Secret|password|Password)" \
  "3" "전역/static 변수에 토큰 저장 금지 → Secure Storage 사용"

# 프로덕션 로그에 민감정보
grep_check "$DART_FILES" "print\(.*token|print\(.*password|debugPrint\(.*token|log\(.*password" \
  "3" "로그에 토큰/비밀번호 출력 금지"

grep_check "$JS_FILES$JSX_FILES" "console\.log\(.*token|console\.log\(.*password|console\.log\(.*secret" \
  "3" "console.log에 민감정보 출력 금지"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 4 — 인증 & 인가
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 4] 인증 & 인가${NC}"

# WebView 안 OAuth 금지
grep_check "$DART_FILES" "WebView.*oauth|webview.*login|loadUrl.*oauth|loadRequest.*oauth" \
  "4" "WebView 안에서 OAuth 처리 금지 → flutter_appauth 사용"

# Implicit Flow 금지
grep_check "$DART_FILES$JS_FILES$JSX_FILES" "response_type.*token[^_]|responseType.*token[^_]" \
  "4" "OAuth Implicit Flow 금지 → PKCE 사용"

# 영구 로그인 (세션 만료 없음)
grep_check "$DART_FILES" "expiresIn.*0\b|expiresAt.*null\b|never.*expir" \
  "4" "세션 만료 없는 영구 로그인 금지"

# 에러 메시지 계정 열거 노출
grep_check "$DART_FILES$JS_FILES$JSX_FILES" \
  "(이메일|email).*존재|password.*틀렸|비밀번호가 틀|user.*not.*found.*email|wrong.*password" \
  "4" "에러 메시지 계정 열거 노출 금지 → 통합 메시지 사용"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 5 — RBAC
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 5] RBAC${NC}"

# 클라이언트 사이드 역할 판단
grep_check "$DART_FILES" "if.*role.*==.*admin|if.*isAdmin.*true" \
  "5" "클라이언트에서 관리자 권한 판단 금지 → 서버/Rules에서 검증" \
  "//.*|test|mock"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 6 — 네트워크 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 6] 네트워크 보안${NC}"

# badCertificateCallback 인증서 검증 해제
grep_check "$DART_FILES" "badCertificateCallback.*=>.*true|badCertificateCallback.*return.*true" \
  "6" "인증서 검증 완전 해제 절대 금지 (MITM 취약)"

# HTTP 사용 (HTTPS 미적용)
grep_check "$DART_FILES$JS_FILES$JSX_FILES" \
  "http://(?!localhost|127\.0\.0\.1|10\.0\.)" \
  "6" "HTTP 사용 금지 → HTTPS 필수 (localhost 제외)"

# NSAllowsArbitraryLoads
grep_check "$PLIST_FILES" "NSAllowsArbitraryLoads.*<true/>" \
  "6" "NSAllowsArbitraryLoads = true 금지 → App Store 리젝 사유"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 7 — 모바일 API 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 7] 모바일 API 보안${NC}"

# 클라이언트가 전달한 userId 파라미터로 DB 조회
grep_check "$JS_FILES$JSX_FILES" \
  "data\.userId|body\.userId|params\.userId|query\.userId" \
  "7" "클라이언트 userId 파라미터로 DB 조회 금지 → 서버에서 토큰 추출"

# Mass Assignment — 요청 객체 그대로 DB 저장
grep_check "$JS_FILES$JSX_FILES" \
  "Object\.assign.*req\.|\.\.\.req\.body|spread.*req\.body" \
  "7" "req.body 전체 DB 저장 금지 (Mass Assignment) → 필드 명시적 선택"

# 무기한 유효 API 토큰
grep_check "$JS_FILES$JSX_FILES" \
  "expiresIn.*'never'|expiresIn.*0\b|no.*expir" \
  "7" "무기한 유효 API 토큰 발급 금지"

# GraphQL 플레이그라운드 프로덕션 활성화
grep_check "$JS_FILES$JSX_FILES" \
  "playground.*true|introspection.*true" \
  "7" "프로덕션 GraphQL 플레이그라운드/introspection 활성화 금지" \
  "dev|development|NODE_ENV.*dev"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 8 — 앱 내부 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 8] 앱 내부 보안${NC}"

# WebView JS 브릿지로 토큰 노출
grep_check "$DART_FILES" \
  "addJavaScriptChannel.*token|postMessage.*token|JavascriptChannel.*secret" \
  "8" "JS 브릿지로 토큰/민감정보 노출 금지"

# 사용자 입력 URL 직접 로드
grep_check "$DART_FILES" \
  "loadRequest.*userInput|loadUrl.*userInput|loadUrl.*\$\{|loadRequest.*\$\{" \
  "8" "사용자 입력 URL 직접 WebView 로드 금지"

# UGC HTML 위젯 직접 전달
grep_check "$DART_FILES" \
  "Html\(.*userInput|Html\(.*\$\{|flutter_html.*unsanitized" \
  "8" "사용자 입력 그대로 Html() 위젯 전달 금지 → 서버사이드 새니타이징 필수"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 9 — 앱 무결성
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 9] 앱 무결성${NC}"

# 디버그 자격증명 하드코딩
grep_check "$DART_FILES$JS_FILES$JSX_FILES" \
  "debugPassword|debug_password|admin1234|password.*1234|test.*password.*=.*['\"]" \
  "9" "디버그용 하드코딩 자격증명 금지 → kDebugMode 분기 또는 환경변수"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 10 — Firebase 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 10] Firebase 보안${NC}"

# allow read, write: if true — 절대 금지
grep_check "$RULES_FILES$ALL_FILES" \
  "allow read, write: if true|allow write: if true|allow read: if true" \
  "10" "Firebase Rules 전체 허용(if true) 절대 금지" \
  "//.*"

# test mode 프로덕션 배포
grep_check "$RULES_FILES" \
  "allow read, write" \
  "10" "Firebase Rules 전체 허용 패턴 감지 — 조건 확인 필요"

# Cloud Functions console.log PII
grep_check "$JS_FILES$JSX_FILES" \
  "console\.log.*uid|console\.log.*email|console\.log.*phone|console\.log.*token" \
  "10" "Cloud Functions에서 PII/토큰 console.log 금지"

# onRequest 인증 없이 민감 작업
grep_check "$JS_FILES$JSX_FILES" \
  "functions\.https\.onRequest.*async.*\{$" \
  "10" "onRequest 함수 — 인증 미들웨어 적용 여부 반드시 확인 (PART 10)"

# Race Condition — Read-then-Write
grep_check "$JS_FILES$JSX_FILES$DART_FILES" \
  "\.get\(\).*\.then.*\.update\(|get\(.*\).*set\(|get\(.*\).*update\(" \
  "10" "Read-then-Write 패턴 감지 → Race Condition 위험 — Firestore 트랜잭션 사용"

# FCM 페이로드에 민감 데이터
grep_check "$JS_FILES$JSX_FILES$DART_FILES" \
  "notification.*token|notification.*password|notification.*secret|data.*token.*fcm" \
  "10" "FCM 페이로드에 토큰/비밀번호 포함 금지"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 11 — Supabase 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 11] Supabase 보안${NC}"

# service_role 키 클라이언트 사용
grep_check "$DART_FILES$JS_FILES$JSX_FILES" \
  "service_role|serviceRole" \
  "11" "service_role 키 클라이언트 사용 금지 → 서버사이드 전용"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 12 — Next.js 웹앱 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 12] Next.js 보안${NC}"

# .env 파일 커밋
if [[ -n "$ENV_FILES" ]]; then
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    # .env.example, .env.sample은 허용
    if echo "$file" | grep -qvE '\.(example|sample|template)$'; then
      local_content=$(git show ":$file" 2>/dev/null || cat "$file" 2>/dev/null || true)
      if echo "$local_content" | grep -qE '[A-Z_]{5,}\s*=\s*[^$\{]'; then
        fail "12" ".env 파일 커밋 금지 — 실제 시크릿 포함 가능성" "$file" "—"
      fi
    fi
  done < <(echo "$ENV_FILES")
fi

# NEXT_PUBLIC_ 서버 시크릿 노출
grep_check "$JS_FILES$JSX_FILES" \
  "NEXT_PUBLIC_.*SECRET|NEXT_PUBLIC_.*PRIVATE|NEXT_PUBLIC_.*_KEY\b" \
  "12" "서버 시크릿을 NEXT_PUBLIC_ 환경변수로 노출 금지"

# 오픈 리다이렉트
grep_check "$JS_FILES$JSX_FILES" \
  "redirect\(.*req\.|redirect\(.*query\.|redirect\(.*params\." \
  "12" "사용자 입력으로 redirect 금지 → 허용 URL 화이트리스트 검증"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 13 — 공급망 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 13] 공급망 보안${NC}"

# pubspec.yaml any 버전 사용
if echo "$STAGED" | grep -q "pubspec\.yaml"; then
  pubspec_content=$(git show ":pubspec.yaml" 2>/dev/null || cat "pubspec.yaml" 2>/dev/null || true)
  if echo "$pubspec_content" | grep -qE ':\s+any\b'; then
    fail "13" "pubspec.yaml 'any' 버전 사용 금지 → ^x.y.z 고정" "pubspec.yaml" "—"
  fi
fi

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 16 — 결제 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 16] 결제 보안${NC}"

# PG Secret Key 클라이언트 포함
grep_check "$DART_FILES" \
  "stripeSecretKey|stripe_secret|tossSecretKey|toss_secret|pgSecretKey|pg_secret" \
  "16" "결제 Secret Key 클라이언트 포함 금지 → 서버사이드 전용"

# 결제 완료를 클라이언트 변수로 판단
grep_check "$DART_FILES" \
  "isPaid\s*=\s*true|paymentSuccess\s*=\s*true|isSubscribed\s*=\s*true" \
  "16" "클라이언트 변수로 결제 완료 판단 금지 → 서버 검증 필수"

# 결제 화면 WebView
grep_check "$DART_FILES" \
  "WebView.*pay|WebView.*결제|WebViewWidget.*checkout" \
  "16" "결제 화면 WebView 사용 금지 (오버레이 공격 위험)"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# PART 17 — AI 에이전트 보안
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[PART 17] AI 에이전트 보안${NC}"

# eval/exec에 AI 출력 전달
grep_check "$JS_FILES$JSX_FILES$DART_FILES" \
  "eval\(.*llm|eval\(.*ai|eval\(.*completion|exec\(.*ai" \
  "17" "eval()/exec()에 AI 출력 직접 전달 금지"

# 미검증 외부 문서 RAG 삽입
grep_check "$JS_FILES$JSX_FILES" \
  "vectorStore.*push\(.*fetch|embeddings.*push\(.*url" \
  "17" "미검증 외부 문서 RAG 파이프라인 직접 삽입 금지"

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# 시크릿 패턴 스캔 (전체 파일)
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}[SECRET] API 키 패턴 스캔${NC}"

SECRET_PATTERNS=(
  "sk-[A-Za-z0-9]{20,}"
  "AIza[A-Za-z0-9_\-]{35}"
  "AAAA[A-Za-z0-9_\-]{140,}"
  "eyJ[A-Za-z0-9_\-]{50,}"
  "-----BEGIN (RSA |EC )?PRIVATE KEY-----"
  "ghp_[A-Za-z0-9]{36}"
  "github_pat_[A-Za-z0-9_]{82}"
)

for pattern in "${SECRET_PATTERNS[@]}"; do
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    [[ ! -f "$file" ]] && continue
    content=$(git show ":$file" 2>/dev/null || cat "$file" 2>/dev/null || true)
    if echo "$content" | grep -qE "$pattern"; then
      linenum=$(echo "$content" | grep -nE "$pattern" | head -1 | cut -d: -f1)
      fail "3" "시크릿 패턴 감지 (${pattern:0:20}...)" "$file" "${linenum:-?}"
    fi
  done < <(echo "$ALL_FILES")
done

# .gitignore에 .env 포함 여부 확인
if [[ -f ".gitignore" ]]; then
  if ! grep -q "^\.env" .gitignore; then
    warn "12" ".gitignore에 .env 미포함 — 시크릿 커밋 위험" ""
  fi
fi

echo ""

# ══════════════════════════════════════════════════════════════════════════════
# 결과 출력
# ══════════════════════════════════════════════════════════════════════════════
echo -e "${BLD}${CYN}══════════════════════════════════════════════${NC}"

if [[ $VIOLATIONS -gt 0 ]]; then
  echo -e "${BLD}${RED}  ✗ COMMIT BLOCKED — 보안 위반 ${VIOLATIONS}건${NC}"
  echo -e "${RED}  SECURITY_MASTER v1.0 [금지] 항목 위반${NC}"
  echo -e "${RED}  위 항목을 수정 후 다시 커밋하세요${NC}"
  echo -e "${BLD}${CYN}══════════════════════════════════════════════${NC}"
  echo ""
  exit 1
fi

if [[ $WARNINGS -gt 0 ]]; then
  echo -e "${BLD}${YEL}  ⚠ COMMIT ALLOWED — 경고 ${WARNINGS}건 (확인 권장)${NC}"
else
  echo -e "${BLD}${GRN}  ✓ COMMIT ALLOWED — 보안 검사 통과${NC}"
fi

echo -e "${BLD}${CYN}══════════════════════════════════════════════${NC}"
echo ""
exit 0
